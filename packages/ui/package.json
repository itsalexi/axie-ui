{
  "name": "@axie/ui",
  "version": "0.1.0",
  "description": "A warm, tactile React component system for focused product apps.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "homepage": "https://axie.alexi.life",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itsalexi/axie-ui.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/itsalexi/axie-ui/issues"
  },
  "keywords": [
    "react",
    "components",
    "ui",
    "design-system",
    "shadcn"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && cp src/styles.css dist/styles.css",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-slot": "latest",
    "cmdk": "^1.1.1"
  },
  "peerDependencies": {
    "react": ">=18.2.0",
    "react-dom": ">=18.2.0"
  },
  "devDependencies": {
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "typescript": "latest"
  }
}
